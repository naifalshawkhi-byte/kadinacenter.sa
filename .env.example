# انسخ هذا الملف إلى .env.local (تطوير) أو .env.production (إنتاج)
# لا ترفع ملف .env إلى Git أبداً

# مطلوب في الإنتاج — ولّد مفتاح عشوائي:
# openssl rand -hex 32
AUTH_SECRET=

# الرابط العام الكامل للتطبيق (بدون / في النهاية)
# أمثلة:
#   https://book.kadinaclinic.com
#   https://yourclinic.com/book  (إذا استخدمت reverse proxy على نفس الدومين)
NEXT_PUBLIC_APP_URL=

# مطلوب فقط عند أول تشغيل في الإنتاج (إنشاء حساب الأدمن)
# 10+ أحرف — غيّر كلمة المرور بعد أول دخول
INITIAL_ADMIN_PASSWORD=

# بيئة التشغيل
NODE_ENV=production
