# إعداد Nginx — WordPress + Next.js على نفس السيرفر

# الخيار 1 (مُوصى به): دومين/سابدومين منفصل للتطبيق
# WordPress: https://yourclinic.com
# الحجز واللوحة: https://book.yourclinic.com

server {
    listen 443 ssl http2;
    server_name book.yourclinic.com;

    ssl_certificate     /etc/letsencrypt/live/book.yourclinic.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/book.yourclinic.com/privkey.pem;

    # حد أقصى لرفع الشعار
    client_max_body_size 2m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

